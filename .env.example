# =============================================================================
# React app (src/) — Vite reads these from the PROJECT ROOT when you run
#   npm run dev   or   npm run build
# Copy to `.env` or `.env.production` and adjust. Do not put secrets here that
# belong only in Laravel (`app.apimstec.com/.env`).
# =============================================================================

# Laravel public API (no trailing slash).
# Local: run CMS from app.apimstec.com with `php artisan serve` (port 8000).
# Live: your deployed CMS hostname (must allow CORS from the React site origin).
VITE_API_URL=http://localhost:8000

# Must match the `domain` column for this website in CMS → Domains.
# Sent as header X-Domain so /api/public/* uses the correct tenant database.
VITE_SITE_DOMAIN=compresspdf.id

# --- Example production file: `.env.production` (used automatically by `vite build`)
# VITE_API_URL=https://app.apimstec.com
# VITE_SITE_DOMAIN=compresspdf.id
