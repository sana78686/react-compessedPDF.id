# =============================================================================
# React app (src/) — Vite reads these from the PROJECT ROOT when you run
#   npm run dev   or   npm run build
#
# Local dev defaults: `.env.development` (committed) sets API + tenant domain for
#   `npm run dev`. Override in `.env.local` (gitignored) if your ports differ.
# Production: use `.env.production` (see that file in repo) or CI env; do not rely on `.env.development`.
# =============================================================================

# Laravel public API (no trailing slash).
# Local: CMS on port 3000 → php artisan serve --port=3000 (see app.apimstec.com/.env APP_URL).
# React Vite defaults to port 2000 (vite.config.js); LOCAL_DEMO_FRONTEND_URL in CMS .env should match.
# Live: your deployed CMS hostname (must allow CORS from the React site origin).
VITE_API_URL=http://localhost:3000

# Fallback site domain for Vite build (SEO inject). Live app uses window.location.hostname in API URLs:
#   {VITE_API_URL}/{VITE_SITE_DOMAIN}/api/public/...
VITE_SITE_DOMAIN=compresspdf.id

# Optional: canonical public origin for fallback sitemap.xml <loc> when CMS download fails (www vs apex).
# Default: https://{VITE_SITE_DOMAIN}
# VITE_PUBLIC_SITE_ORIGIN=https://www.compresspdf.id
# Local: must match CMS → Domains row (`compresspdf.local` after cms:local-bootstrap). `.env.development` sets this for `npm run dev`.

# Locale for ?locale=… when baking HOME page meta into index.html at build (crawlers / view-source).
# Must match the CMS home content language you want in that static HTML (en, id, etc.).
# VITE_BUILD_SEO_LOCALE=en

# Shown in default home SEO block (simple English fallback when CMS home content is empty).
# VITE_PUBLIC_SITE_NAME=Compress PDF

# true (default): try /{domain}/api/public/... then auto-fallback to /api/public/... + X-Domain on 404/403.
# false: only /api/public/... + X-Domain (use on nginx/Plesk if the host path never reaches Laravel).
# VITE_API_DOMAIN_PATH=false

# Public GET cache (ms) — same-tab repeat visits hit memory/sessionStorage first (faster CMS-driven pages).
# CMS saves bump `updated_at`; GET /api/public/content-revision invalidates local cache when newer than last visit
# (see localStorage key cms:content-revision:v1). Long TTL is OK after deploy; republish still clears stale data.
# Set to 0 while debugging stale CMS content after publish; or hard-refresh / clear sessionStorage keys prefixed cms:v1:
# VITE_CMS_CACHE_MS=120000
# false = disable sessionStorage persistence (memory-only dedupe + TTL).
# VITE_CMS_SESSION_CACHE=true

# Optional: GA4 Measurement ID (G-…) when CMS API is unavailable or returns no ID (local dev only).
# Production: set GA4 in CMS → SEO → Analytics and/or paste full gtag snippet in Content → Home → head HTML.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Example production file: `.env.production` (used automatically by `vite build`)
# VITE_API_URL=https://app.apimstec.com
# VITE_SITE_DOMAIN=compresspdf.id

# After `npm run build`, fetch sitemap.xml + robots.txt from CMS into dist/ (same domain as the site).
# Set false if your host generates them another way.
# VITE_FETCH_SEO_FILES=true

# Build: write dist/cms-prefetch.json (home, FAQ, pages, blogs, cards, legal-nav, contact per locale).
# Runtime loads it only if its `revision` matches live GET /content-revision (fast first paint).
# Comma/space-separated locale codes (must exist in CMS).
# VITE_CMS_PREFETCH_LOCALES=id,en,ms,es,fr,ar,ru
# VITE_CMS_PREFETCH=false

# Images: default is same-origin https://{your-site}/uploads/... (nginx proxies /uploads → CMS /storage).
# Only if you cannot proxy /uploads, set true to load images via the CMS API (URLs show the API host).
# VITE_USE_CMS_MEDIA_PROXY=false

# --- Multi-site CMS: in Laravel → Domains → edit each site and set "Frontend URL" to the live React origin
# (e.g. https://compresspdf.id). Uploads + public JSON then use that host for image and canonical URLs.
#
# --- Nginx (or similar) on the React server — proxy uploads to the CMS public disk:
#   location /uploads/ {
#     proxy_pass https://YOUR_CMS_HOST/storage/;
#     proxy_set_header Host YOUR_CMS_HOST;
#   }
# Google Search Console “Sitemap is HTML”: the host is serving index.html for /sitemap.xml. Fix:
#   1) Ensure dist/sitemap.xml exists after build (run npm run build; upload full dist/).
#   2) Nginx: try_files must see the real file BEFORE SPA fallback, e.g.
#        root /var/www/compresspdf/dist;
#        location = /sitemap.xml { try_files /sitemap.xml =404; default_type application/xml; }
#        location = /robots.txt  { try_files /robots.txt =404;  default_type text/plain; }
#        location / { try_files $uri $uri/ /index.html; }
#   3) Or proxy to CMS (full sitemap with all URLs):
#        location = /sitemap.xml { proxy_pass https://YOUR_CMS_HOST/YOUR_SITE_DOMAIN/sitemap.xml; ... }
#        location = /robots.txt  { proxy_pass https://YOUR_CMS_HOST/YOUR_SITE_DOMAIN/robots.txt; ... }
