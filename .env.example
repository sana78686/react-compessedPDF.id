# Laravel backend (compressedPDF-cms) – public API base URL (no trailing slash)
# Development: backend on port 8000. Live: frontend is on pdf.apimstec.com and CMS/API on https://portal.compressedpdf.apimstec.com
# If unset in production build, the frontend defaults to https://portal.compressedpdf.apimstec.com
VITE_API_URL=http://localhost:8000
# For production build (optional – code already defaults to https://portal.compressedpdf.apimstec.com):
# VITE_API_URL=https://portal.compressedpdf.apimstec.com
