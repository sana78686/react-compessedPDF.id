APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Optional: auto-filled when you switch domain in the CMS (master stays on DB_* above)
# CMS_TENANT_HOST=
# CMS_TENANT_PORT=
# CMS_TENANT_DATABASE=
# CMS_TENANT_USERNAME=
# CMS_TENANT_PASSWORD=

SESSION_DRIVER=database
# Optional override; if unset, uses DB_CONNECTION (registry — not tenant when a site is active)
# SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Use redis in production for public API response cache + CORS origin list cache (many sites).
# Install Redis server, then: CACHE_STORE=redis
# Without the phpredis PHP extension, set REDIS_CLIENT=predis (composer package predis/predis).
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Public contact form (React) — all submissions go here; subject/body include CONTACT_FORM_SITE_NAME.
CONTACT_FORM_MAIL_TO=apimstecofficial@gmail.com
CONTACT_FORM_SITE_NAME="${APP_NAME}"

# Extra CORS origins (comma-separated). Main list is built from Domains (domain + frontend_url), cached.
# CORS_ALLOWED_ORIGINS=https://preview.example.com,http://localhost:4173
# CORS_ORIGINS_CACHE_TTL=3600

# Public JSON API cache (GET /api/public/*) — TTL seconds, per X-Domain + path
# PUBLIC_API_CACHE_ENABLED=true
# PUBLIC_API_CACHE_TTL=300

# Google OAuth — live Search Console metrics (SEO → Analytics). Enable “Google Search Console API” in Cloud Console.
# Redirect URI must match exactly (no /en/ prefix): {APP_URL}/oauth/google-search-console/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_GSC_REDIRECT_URI="${APP_URL}/oauth/google-search-console/callback"

# Sitemap/robots: allow resolving tenant by hostname even when Domain.is_active is false (CMS session still requires active).
# SEO_ALLOW_INACTIVE_FOR_SITEMAP_ROBOTS=true
